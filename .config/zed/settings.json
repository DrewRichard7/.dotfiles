  //       "args": ["--login", "-i"],
  //     },
  //   },
  // },
  "edit_predictions": {
    "copilot": {
      "enable_next_edit_suggestions": false,
    },
    "provider": "none",
    "mode": "subtle",
  },
  "project_panel": {
    "dock": "left",
    "entry_spacing": "standard",
  },
  "git_panel": {
    "dock": "left",
    "sort_by_path": false,
  },
  "cursor_blink": false,
  "horizontal_scroll_margin": 5.0,
  "vertical_scroll_margin": 10.0,
  "relative_line_numbers": "enabled",
